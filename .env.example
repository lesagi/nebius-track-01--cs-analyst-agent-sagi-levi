# Secrets only - everything non-secret lives in config.yaml.
# Copy to .env and fill in what you use.

# Required when provider is nebius (config.yaml or MODEL_PROVIDER=nebius):
# NEBIUS_API_KEY="..."

# Optional: LangSmith tracing.
# LANGSMITH_API_KEY="..."

# Optional overrides (normally set in config.yaml):
# MODEL_PROVIDER=nebius                      # which models block is active
# BITEXT_DATASET_PATH="bitext_dataset.csv"   # loader source, e.g. a local CSV
# BITEXT_DB_PATH="bitext.sqlite"
# MODEL_CONTEXT_TOKENS=262144
# MAX_LLM_CALLS=12
